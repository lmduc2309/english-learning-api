# Server Configuration
PORT=7474
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=english_learning

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# vLLM Configuration (for translation and fallback)
VLLM_URL=http://localhost:8000/v1/completions
VLLM_MODEL=microsoft/Phi-3-mini-4k-instruct

# Dictionary LLM Fallback
# Set to 'false' to disable LLM fallback for dictionary lookups
# When disabled, only words in the database will be returned (recommended after importing dictionary data)
# When enabled (default), unknown words will be generated using LLM
LLM_FALLBACK_ENABLED=true

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379